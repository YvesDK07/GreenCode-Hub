<%- include('partials/header') %>
<div class="container section">
  <div class="snippet-header">
    <h1><%= snippet.title %></h1>
    <div class="meta">
      <%= snippet.language %> · <%= snippet.category_name %> · par @<%= snippet.author_name || 'anonyme' %> · <%= new Date(snippet.created_at).toLocaleDateString('fr-FR') %>
    </div>
  </div>

  <div class="code-block"><%= snippet.code %></div>

  <div class="metrics-grid">
    <div class="metric">
      <div class="label">Complexite temps</div>
      <div class="value"><%= snippet.complexity_time %></div>
    </div>
    <% if (snippet.complexity_space) { %>
    <div class="metric">
      <div class="label">Complexite espace</div>
      <div class="value"><%= snippet.complexity_space %></div>
    </div>
    <% } %>
    <div class="metric">
      <div class="label">Score sobriete</div>
      <div class="value"><%= '★'.repeat(snippet.energy_score) %><%= '☆'.repeat(5 - snippet.energy_score) %></div>
    </div>
    <div class="metric">
      <div class="label">Votes</div>
      <div class="value"><%= snippet.vote_count %></div>
    </div>
  </div>

  <div class="actions">
    <% if (user) { %>
      <form method="POST" action="/snippet/<%= snippet.id %>/vote" style="display:inline;">
        <button type="submit" class="vote-btn <%= userVoted ? 'active' : '' %>">
          ▲ <%= userVoted ? 'Vote' : 'Voter' %>
        </button>
      </form>
    <% } else { %>
      <a href="/login" class="btn btn-outline">Connectez-vous pour voter</a>
    <% } %>

    <% if (user && (user.id === snippet.author_id || user.role === 'admin')) { %>
      <a href="/snippet/<%= snippet.id %>/edit" class="btn btn-outline">Modifier</a>
      <form method="POST" action="/snippet/<%= snippet.id %>/delete" style="display:inline;" onsubmit="return confirm('Supprimer ce snippet ?')">
        <button type="submit" class="btn btn-danger">Supprimer</button>
      </form>
    <% } %>
  </div>

  <a href="/catalogue" style="font-size: 0.9rem;">&larr; Retour au catalogue</a>
</div>
<%- include('partials/footer') %>
