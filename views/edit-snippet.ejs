<%- include('partials/header') %>
<div class="form-page" style="max-width: 640px;">
  <h1>Modifier le snippet</h1>
  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
  <form method="POST" action="/snippet/<%= snippet.id %>/edit">
    <div class="form-group">
      <label for="title">Titre</label>
      <input type="text" id="title" name="title" value="<%= snippet.title %>" required>
    </div>
    <div class="form-group">
      <label for="language">Langage</label>
      <input type="text" id="language" name="language" value="<%= snippet.language %>" required>
    </div>
    <div class="form-group">
      <label for="category_id">Categorie</label>
      <select name="category_id" id="category_id" required>
        <% categories.forEach(c => { %>
          <option value="<%= c.id %>" <%= snippet.category_id === c.id ? 'selected' : '' %>><%= c.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-group">
      <label for="code">Code</label>
      <textarea id="code" name="code" required><%= snippet.code %></textarea>
    </div>
    <div class="form-group">
      <label for="complexity_time">Complexite temporelle</label>
      <input type="text" id="complexity_time" name="complexity_time" value="<%= snippet.complexity_time %>" required>
    </div>
    <div class="form-group">
      <label for="complexity_space">Complexite spatiale (optionnel)</label>
      <input type="text" id="complexity_space" name="complexity_space" value="<%= snippet.complexity_space || '' %>">
    </div>
    <div class="form-group">
      <label for="energy_score">Score de sobriete</label>
      <select name="energy_score" id="energy_score" required>
        <% for (let i = 5; i >= 1; i--) { %>
          <option value="<%= i %>" <%= snippet.energy_score === i ? 'selected' : '' %>><%= i %></option>
        <% } %>
      </select>
    </div>
    <button type="submit" class="btn btn-primary" style="width:100%;">Enregistrer</button>
  </form>
  <p style="margin-top:1rem;"><a href="/snippet/<%= snippet.id %>">&larr; Annuler</a></p>
</div>
<%- include('partials/footer') %>
