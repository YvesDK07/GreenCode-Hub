<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>GreenCode Hub</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header>
    <div class="container">
      <a href="/" class="logo"><span>&lt;/&gt;</span> GreenCode Hub</a>
      <nav>
        <a href="/">Accueil</a>
        <a href="/catalogue">Catalogue</a>
        <a href="/about">À propos</a>
        <% if (user) { %>
          <a href="/new">+ Snippet</a>
          <a href="/profile"><%= user.username %></a>
          <a href="/logout">Déconnexion</a>
        <% } else { %>
          <a href="/login" class="btn-sm">Connexion</a>
        <% } %>
      </nav>
    </div>
  </header>
