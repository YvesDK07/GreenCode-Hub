<%- include('partials/header') %>
<div class="container section">
  <h1 style="color: var(--blue-dark); margin-bottom: 1rem;">Mon profil</h1>

  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
  <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

  <div class="profile-info">
    <div><strong>Utilisateur :</strong> @<%= profile.username %></div>
    <div><strong>Email :</strong> <%= profile.email %></div>
    <div><strong>Inscrit le :</strong> <%= new Date(profile.created_at).toLocaleDateString('fr-FR') %></div>
    <div><strong>Role :</strong> <%= profile.role %></div>
    <div><strong>Snippets publies :</strong> <%= snippets.length %></div>
    <div><strong>Votes donnes :</strong> <%= voteCount %></div>
  </div>

  <h2 style="color: var(--blue-dark); margin-bottom: 1rem;">Modifier mon profil</h2>
  <form method="POST" action="/profile" style="max-width: 480px;">
    <div class="form-group">
      <label for="username">Nom d'utilisateur</label>
      <input type="text" id="username" name="username" value="<%= profile.username %>" required>
    </div>
    <div class="form-group">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" value="<%= profile.email %>" required>
    </div>
    <div class="form-group">
      <label for="password">Mot de passe actuel (obligatoire)</label>
      <input type="password" id="password" name="password" required>
    </div>
    <div class="form-group">
      <label for="password_new">Nouveau mot de passe (optionnel, 6 car. min)</label>
      <input type="password" id="password_new" name="password_new" minlength="6">
    </div>
    <button type="submit" class="btn btn-primary">Enregistrer</button>
  </form>

  <% if (snippets.length > 0) { %>
    <h2 style="color: var(--blue-dark); margin: 2rem 0 1rem;">Mes snippets</h2>
    <div class="cards">
      <% snippets.forEach(s => { %>
        <div class="card">
          <h3><a href="/snippet/<%= s.id %>"><%= s.title %></a></h3>
          <div class="meta"><%= s.language %> · <%= s.category_name %> · ▲ <%= s.vote_count %></div>
          <div class="actions" style="margin-top: 0.5rem;">
            <a href="/snippet/<%= s.id %>/edit" class="btn btn-outline" style="font-size:0.8rem; padding:0.3rem 0.6rem;">Modifier</a>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <div class="danger-zone">
    <h3>Zone dangereuse</h3>
    <p>La suppression de votre compte est irreversible. Vos snippets seront conserves mais dissocies de votre profil.</p>
    <form method="POST" action="/profile/delete" onsubmit="return confirm('Etes-vous sur de vouloir supprimer votre compte ? Cette action est irreversible.')">
      <button type="submit" class="btn btn-danger">Supprimer mon compte</button>
    </form>
  </div>
</div>
<%- include('partials/footer') %>
