<%- include('partials/header') %>
<div class="container section">
  <div style="display: flex; align-items: baseline; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
    <h1 style="color: var(--blue-dark); margin: 0;">Gestion des utilisateurs</h1>
    <a href="/admin" class="btn btn-outline">← Retour admin</a>
  </div>
  <p style="color: #666; margin: 0.5rem 0 1.5rem;"><%= total %> utilisateur(s) au total · Page <%= page %> / <%= totalPages %></p>

  <% if (typeof query !== 'undefined' && query) { %><% } %>
  <% const q = (typeof url !== 'undefined' ? url : ''); %>
  <% /* Flash messages from query string */ %>
  <% const _err = (typeof errMsg !== 'undefined') ? errMsg : null; %>

  <%
    const errors = {
      self: 'Vous ne pouvez pas modifier ou supprimer votre propre compte depuis cette page.',
      lastadmin: 'Action refusée : il doit toujours rester au moins un administrateur.',
    };
    const successes = {
      role: 'Rôle modifié avec succès.',
      del: 'Utilisateur supprimé avec succès.',
    };
  %>
  <% const errKey = (typeof query !== 'undefined' ? query.err : null); %>

  <script>
    // Read flash messages from URL on the server-side via EJS:
  </script>

  <% /* Render flash from URL params via res.locals or fall back to alerts */ %>

  <table class="admin-table" style="width:100%; border-collapse: collapse; margin-bottom: 1.5rem;">
    <thead>
      <tr style="text-align:left; border-bottom: 2px solid var(--green); background:#f7faf7;">
        <th style="padding: 0.6rem;">Utilisateur</th>
        <th style="padding: 0.6rem;">Email</th>
        <th style="padding: 0.6rem;">Rôle</th>
        <th style="padding: 0.6rem;">Snippets</th>
        <th style="padding: 0.6rem;">Votes</th>
        <th style="padding: 0.6rem;">Inscrit le</th>
        <th style="padding: 0.6rem;">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(u => { %>
        <tr style="border-bottom: 1px solid #eee;">
          <td style="padding: 0.6rem;">@<%= u.username %><% if (u.id === currentUserId) { %> <span class="meta">(vous)</span><% } %></td>
          <td style="padding: 0.6rem;"><%= u.email %></td>
          <td style="padding: 0.6rem;">
            <% if (u.role === 'admin') { %>
              <span style="background: var(--blue-dark); color: white; padding: 0.15rem 0.5rem; border-radius: 4px; font-size: 0.8rem;">admin</span>
            <% } else { %>
              <span style="background: #eee; padding: 0.15rem 0.5rem; border-radius: 4px; font-size: 0.8rem;">user</span>
            <% } %>
          </td>
          <td style="padding: 0.6rem;"><%= u.snippet_count %></td>
          <td style="padding: 0.6rem;"><%= u.vote_count %></td>
          <td style="padding: 0.6rem;"><%= new Date(u.created_at).toLocaleDateString('fr-FR') %></td>
          <td style="padding: 0.6rem;">
            <% if (u.id !== currentUserId) { %>
              <form method="POST" action="/admin/users/<%= u.id %>/role" style="display:inline;">
                <button type="submit" class="btn btn-outline" style="font-size:0.8rem; padding:0.25rem 0.5rem;" aria-label="Basculer le rôle de <%= u.username %>">
                  <% if (u.role === 'admin') { %>↓ user<% } else { %>↑ admin<% } %>
                </button>
              </form>
              <form method="POST" action="/admin/users/<%= u.id %>/delete" style="display:inline;" onsubmit="return confirm('Supprimer définitivement @<%= u.username %> ? Ses snippets seront conservés mais anonymisés.');">
                <button type="submit" class="btn btn-danger" style="font-size:0.8rem; padding:0.25rem 0.5rem;" aria-label="Supprimer <%= u.username %>">Supprimer</button>
              </form>
            <% } else { %>
              <span class="meta">—</span>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <% if (totalPages > 1) { %>
    <nav style="display: flex; gap: 0.5rem; justify-content: center;" aria-label="Pagination">
      <% if (page > 1) { %>
        <a href="/admin/users?page=<%= page - 1 %>" class="btn btn-outline">← Précédent</a>
      <% } %>
      <span style="padding: 0.5rem 1rem;">Page <%= page %> / <%= totalPages %></span>
      <% if (page < totalPages) { %>
        <a href="/admin/users?page=<%= page + 1 %>" class="btn btn-outline">Suivant →</a>
      <% } %>
    </nav>
  <% } %>
</div>

<script>
  // Flash messages from query string (lightweight, no JS framework)
  (function() {
    const params = new URLSearchParams(window.location.search);
    const err = params.get('err');
    const ok = params.get('ok');
    const errors = {
      self: 'Vous ne pouvez pas modifier ou supprimer votre propre compte.',
      lastadmin: 'Action refusée : il doit toujours rester au moins un administrateur.',
    };
    const successes = {
      role: 'Rôle modifié avec succès.',
      del: 'Utilisateur supprimé avec succès.',
    };
    const msg = errors[err] || successes[ok];
    if (msg) {
      const div = document.createElement('div');
      div.className = err ? 'alert alert-error' : 'alert alert-success';
      div.textContent = msg;
      div.style.cssText = 'padding:0.75rem 1rem; margin-bottom:1rem; border-radius:4px; ' +
        (err ? 'background:#fdecea; color:#a72b1f; border:1px solid #f5c6cb;' :
               'background:#e8f5e9; color:#1b5e20; border:1px solid #c8e6c9;');
      const container = document.querySelector('.container.section');
      container.insertBefore(div, container.children[1]);
    }
  })();
</script>
<%- include('partials/footer') %>
