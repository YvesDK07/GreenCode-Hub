<%- include('partials/header') %>

<section class="hero">
  <h1>Partagez du code sobre, comparez les solutions</h1>
  <p>La plateforme collaborative du Green Coding</p>
  <a href="/catalogue" class="btn">Explorer le catalogue</a>
</section>

<section class="eco-section">
  <h2>Nos engagements ecologiques</h2>
  <div class="eco-grid">
    <div class="eco-card">
      <strong>&lt; 300 Ko</strong>
      <span>Pages ultra-legeres, rendu cote serveur</span>
    </div>
    <div class="eco-card">
      <strong>Zero tracking</strong>
      <span>Aucun cookie tiers, aucune donnee de navigation collectee</span>
    </div>
    <div class="eco-card">
      <strong>Code sobre</strong>
      <span>Chaque snippet est evalue sur sa sobriete energetique</span>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="stats">
      <div class="stat"><div class="num"><%= stats.snippets %></div><div class="label">Snippets</div></div>
      <div class="stat"><div class="num"><%= stats.users %></div><div class="label">Contributeurs</div></div>
      <div class="stat"><div class="num"><%= stats.votes %></div><div class="label">Votes</div></div>
    </div>

    <h2>Snippets populaires</h2>
    <div class="cards">
      <% popular.forEach(s => { %>
        <div class="card">
          <h3><a href="/snippet/<%= s.id %>"><%= s.title %></a></h3>
          <div class="meta">par @<%= s.author_name || 'anonyme' %> · <%= s.category_name %></div>
          <div class="badges">
            <span class="badge badge-lang"><%= s.language %></span>
            <span class="badge badge-complexity"><%= s.complexity_time %></span>
            <span class="badge badge-score"><%= '★'.repeat(s.energy_score) %><%= '☆'.repeat(5 - s.energy_score) %></span>
            <span class="badge badge-votes">▲ <%= s.vote_count %></span>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
