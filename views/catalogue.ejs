<%- include('partials/header') %>
<div class="container section">
  <h1 style="color: var(--blue-dark); margin-bottom: 1rem;">Catalogue des snippets</h1>

  <form method="GET" action="/catalogue" class="filters">
    <div class="form-group">
      <label for="category">Categorie</label>
      <select name="category" id="category">
        <option value="">Toutes</option>
        <% categories.forEach(c => { %>
          <option value="<%= c.id %>" <%= filters.category == c.id ? 'selected' : '' %>><%= c.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-group">
      <label for="language">Langage</label>
      <select name="language" id="language">
        <option value="">Tous</option>
        <% languages.forEach(l => { %>
          <option value="<%= l %>" <%= filters.language === l ? 'selected' : '' %>><%= l %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-group">
      <label for="sort">Trier par</label>
      <select name="sort" id="sort">
        <option value="recent" <%= filters.sort === 'recent' ? 'selected' : '' %>>Plus recents</option>
        <option value="votes" <%= filters.sort === 'votes' ? 'selected' : '' %>>Plus votes</option>
        <option value="score" <%= filters.sort === 'score' ? 'selected' : '' %>>Meilleur score</option>
      </select>
    </div>
    <button type="submit" class="btn btn-primary">Filtrer</button>
  </form>

  <% if (snippets.length === 0) { %>
    <p style="color: var(--gray-500); text-align: center; padding: 2rem 0;">Aucun snippet trouve. <a href="/new">Soyez le premier a en publier !</a></p>
  <% } else { %>
    <div class="cards">
      <% snippets.forEach(s => { %>
        <div class="card">
          <h3><a href="/snippet/<%= s.id %>"><%= s.title %></a></h3>
          <div class="meta">par @<%= s.author_name || 'anonyme' %> · <%= s.category_name %></div>
          <div class="badges">
            <span class="badge badge-lang"><%= s.language %></span>
            <span class="badge badge-complexity"><%= s.complexity_time %></span>
            <span class="badge badge-score"><%= '★'.repeat(s.energy_score) %><%= '☆'.repeat(5 - s.energy_score) %></span>
            <span class="badge badge-votes">▲ <%= s.vote_count %></span>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
<%- include('partials/footer') %>
